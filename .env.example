# EPAGOGE platform — copy to .env (gitignored) and fill in.
# Local development defaults work with infra/docker-compose.yml.
#
# Quick start for fresh clones:
#   cp .env.example .env
#   # then generate two random 32-byte hex keys for JWT_SECRET and
#   # MASTER_ENCRYPTION_KEY — see commented commands below.
#
# The API auto-loads this file from the repo root at boot
# (apps/api/src/load-env.ts). `override: false` — real platform env vars
# always win in production.

# --- Required for apps/api boot ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Local infra (matches infra/docker-compose.yml) ---
DATABASE_URL=postgres://epagoge:epagoge_dev@localhost:5432/epagoge
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Both must be 64-char lowercase hex (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET signs access + refresh tokens (HS256).
# MASTER_ENCRYPTION_KEY envelope-encrypts per-user secret attestation keys at rest.
JWT_SECRET=replace-with-64-char-hex
MASTER_ENCRYPTION_KEY=replace-with-64-char-hex

# JWT lifetimes (seconds). Defaults: 15 min access, 30 days refresh.
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Frontend ---
# Picked up by apps/web at build time via import.meta.env.VITE_API_URL.
# Defaults to http://localhost:3000 if unset.
VITE_API_URL=http://localhost:3000

# --- AI ---
ANTHROPIC_API_KEY=

# --- Object storage (S3-compatible; Phase 1+) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- External services ---
HUGGINGFACE_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Phase 1+ ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Phase 2+ ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# --- Monitoring (Phase 1+) ---
SENTRY_DSN=
