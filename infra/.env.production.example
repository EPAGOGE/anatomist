# Copy this file to .env.production and fill in real values.
# .env.production is .gitignored — NEVER commit it.

# ---------- Postgres ----------
# Used by the in-network postgres service AND by the api/migrate when
# DATABASE_URL doesn't override.
POSTGRES_USER=epagoge
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=epagoge

# If using managed Postgres (RDS, Cloud SQL, etc.), set this to the
# managed endpoint and the in-network postgres service won't be used.
# Format: postgres://user:pass@host:5432/dbname?sslmode=require
# DATABASE_URL=postgres://...

# ---------- Redis ----------
# Override when using managed Redis (ElastiCache, Memorystore, etc.).
# REDIS_URL=rediss://...

# ---------- Authentication ----------
# 32-byte (256-bit) secret as 64 hex chars. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# 32-byte AES-256 master encryption key, 64 hex chars. Used to envelope-
# encrypt per-user attestation keys at rest (ADR-0020). Generate with:
#   openssl rand -hex 32
# CRITICAL: rotating this WITHOUT a key-rotation plan loses all encrypted
# user keys. Treat it the same way you'd treat a database master password.
MASTER_ENCRYPTION_KEY=

# Token TTLs (defaults: 15 min access, 30 days refresh).
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=2592000

# ---------- Anthropic / AI ----------
# Required for AI features (chat, validation explanations, etc.).
# Without it, the AI features fail closed; non-AI features still work.
ANTHROPIC_API_KEY=

# ---------- Web ----------
# Where the SPA points its API calls (build-time; rebuild image to change).
# Same-origin example: /api  (with an nginx proxy_pass rule)
# Split-origin example: https://api.epagoge.example
VITE_API_BASE_URL=http://localhost:8080/api

# Host port the web service binds. The container always serves on :80
# internally; this maps it to the host.
WEB_PORT=8080
