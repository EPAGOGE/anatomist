# MI Workbench Backend — Environment Configuration

# HuggingFace token (needed for gated models like Gemma 2 — accept license at huggingface.co first)
# Get one at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# RunPod API key (optional — only needed for cloud runtime fallback)
# Get one at: https://www.runpod.io/console/user/settings
# RUNPOD_API_KEY=

# Server config (the MI_ prefix is required — see mi_backend/config.py)
MI_HOST=127.0.0.1
MI_PORT=8765
MI_RELOAD=true

# Model cache directory (where downloaded model weights live)
MI_MODEL_CACHE=./hf_cache

# Default model on startup (loaded lazily on first probe)
MI_DEFAULT_MODEL=gemma-2-2b-it

# Device preference: "auto" picks mps > cuda > cpu
MI_DEVICE=auto

# Log level
MI_LOG_LEVEL=INFO
